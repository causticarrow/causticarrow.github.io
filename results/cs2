<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Betting Results</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/luxon@3.4.4/build/global/luxon.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1.3.1/dist/chartjs-adapter-luxon.min.js"></script>
  <style>
    body { font-family: sans-serif; padding: 20px; background: #121212; color: #fff; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #333; padding: 8px 12px; text-align: center; }
    th { background: #1e1e1e; }
    .positive { color: #4caf50; }
    .negative { color: #f44336; }
  </style>
</head>
<body>
  <h1>My Betting Results</h1>
  <canvas id="pnlChart" height="100"></canvas>
  <table id="resultsTable">
    <thead>
      <tr>
        <th>Date</th><th>Play</th><th>Result</th><th>Units</th>
        <th>Score</th><th>Close</th><th>CLV</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <script>
    // --- Helper functions ---
    function extractOdds(playStr) {
      const match = playStr.match(/\(([-+]?\d+)\)/);
      return match ? match[1] : null;
    }

    function americanToProb(oddsStr) {
      const a = parseInt(oddsStr);
      return a > 0 ? 100 / (a + 100) : (-a) / (-a + 100);
    }

    function calculateUnits(oddsStr, result) {
      const a = parseInt(oddsStr);
      if (result === 'W') return 1.0;
      return a > 0 ? -1.0 : -(a / 100); // if +162: risk 1 to win 1 → loss = -1; but you said: "betting +162 dog, risking 0.62 to win 1"
      // Correction per your spec:
    }

    // ✅ CORRECT UNIT CALCULATION PER YOUR SPEC:
    // "Betting +162 dog → risk 0.62 to win 1"
    // "Betting -162 fav → risk 1.62 to win 1"
    function calculateUnits(oddsStr, result) {
      const a = parseInt(oddsStr);
      const risk = a > 0 ? 100 / a : -a / 100; // risk per 1 unit won
      return result === 'W' ? 1.0 : -risk;
    }

    function calculateCLV(myOdds, closeOdds) {
      const myProb = americanToProb(myOdds);
      const closeProbVig = americanToProb(closeOdds);
      const overround = 1.0476; // -110 market
      const closeProbFair = closeProbVig / overround;
      return (closeProbFair - myProb) * 100; // %
    }

    // --- Load and render ---
    fetch('picks.json')
      .then(res => res.json())
      .then(picks => {
        // Sort: newest first
        picks.sort((a, b) => new Date(b.date) - new Date(a.date));

        const tbody = document.querySelector('#resultsTable tbody');
        const cumulative = [];
        let sum = 0;

        picks.forEach(pick => {
          const myOdds = extractOdds(pick.play);
          if (!myOdds) {
            console.warn('No odds found in play:', pick.play);
            return;
          }

          const units = calculateUnits(myOdds, pick.result);
          sum += units;
          cumulative.push({ x: pick.date, y: sum });

          const clv = calculateCLV(myOdds, pick.close_odds);
          const clvClass = clv >= 0 ? 'positive' : 'negative';
          const unitsClass = units >= 0 ? 'positive' : 'negative';

          const row = `
            <tr>
              <td>${pick.date}</td>
              <td>${pick.play}</td>
              <td>${pick.result}</td>
              <td class="${unitsClass}">${units.toFixed(2)}</td>
              <td>${pick.score}</td>
              <td>${pick.close_odds}</td>
              <td class="${clvClass}">${clv.toFixed(1)}%</td>
            </tr>
          `;
          tbody.innerHTML += row;
        });

        // Chart
        new Chart(document.getElementById('pnlChart'), {
          type: 'line',
          data: {
            datasets: [{
              label: 'Cumulative Units',
              data: cumulative,
              borderColor: '#00ecc3',
              tension: 0.2,
              fill: false
            }]
          },
          options: {
            responsive: true,
            scales: {
              x: { type: 'time', time: { unit: 'day' } },
              y: { grid: { color: '#333' } }
            },
            plugins: { legend: { labels: { color: '#fff' } } }
          }
        });
      });
  </script>
</body>
</html>
